; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[ {
"base": "Node",
"class": "AddBallData",
"language": "GDScript",
"path": "res://data_classes/addball_data.gd"
}, {
"base": "Node",
"class": "BallData",
"language": "GDScript",
"path": "res://data_classes/ball_data.gd"
}, {
"base": "Node",
"class": "BdtParser",
"language": "GDScript",
"path": "res://data_classes/bdt_parser.gd"
}, {
"base": "Node",
"class": "BhdParser",
"language": "GDScript",
"path": "res://data_classes/bhd_parser.gd"
}, {
"base": "Control",
"class": "DesignCanvas",
"language": "GDScript",
"path": "res://scenes/editor/DesignCanvas.gd"
}, {
"base": "Panel",
"class": "DraggablePanel",
"language": "GDScript",
"path": "res://scenes/editor/DraggablePanel.gd"
}, {
"base": "Node",
"class": "LineData",
"language": "GDScript",
"path": "res://data_classes/line_data.gd"
}, {
"base": "Reference",
"class": "LnzLiveUtils",
"language": "GDScript",
"path": "res://data_classes/lnzlive_utils.gd"
}, {
"base": "Node",
"class": "LnzParser",
"language": "GDScript",
"path": "res://data_classes/lnz_parser.gd"
}, {
"base": "Node",
"class": "PaintBallData",
"language": "GDScript",
"path": "res://data_classes/paintball_data.gd"
}, {
"base": "Node",
"class": "PolyData",
"language": "GDScript",
"path": "res://data_classes/polygon_data.gd"
}, {
"base": "Node",
"class": "Section",
"language": "GDScript",
"path": "res://data_classes/section_enum.gd"
} ]
_global_script_class_icons={
"AddBallData": "",
"BallData": "",
"BdtParser": "",
"BhdParser": "",
"DesignCanvas": "",
"DraggablePanel": "",
"LineData": "",
"LnzLiveUtils": "",
"LnzParser": "",
"PaintBallData": "",
"PolyData": "",
"Section": ""
}

[application]

config/name="LnzLive"
config/description="A visual editor for P.F. Magic game files"
run/main_scene="res://scenes/bootsplash.tscn"
run/low_processor_mode=true
run/low_processor_mode_sleep_usec=10000
boot_splash/image="res://launcher/images/launcher_roll_still1.png"
boot_splash/use_filter=false
boot_splash/bg_color=Color( 0.168627, 0.45098, 0.45098, 1 )
config/icon="res://LnzLiveIcon.png"

[autoload]

KeyBallsData="*res://data_classes/key_balls_data.gd"

[debug]

gdscript/warnings/shadowed_variable=false

[display]

window/size/width=1920
window/size/height=1080
window/dpi/allow_hidpi=true
window/energy_saving/keep_screen_on=false
window/stretch/mode="2d"
window/stretch/aspect="expand"
window/stretch/shrink=1.5

[global]

filter=false
default=false
application/config/version=false
application/config/versio=false

[importer_defaults]

texture={
"compress/bptc_ldr": 0,
"compress/hdr_mode": 0,
"compress/lossy_quality": 0.7,
"compress/mode": 0,
"compress/normal_map": 2,
"detect_3d": false,
"flags/anisotropic": false,
"flags/filter": false,
"flags/mipmaps": false,
"flags/repeat": 0,
"flags/srgb": 0,
"process/HDR_as_SRGB": false,
"process/fix_alpha_border": false,
"process/invert_color": false,
"process/premult_alpha": false,
"size_limit": 0,
"stream": false,
"svg/scale": 1.0
}

[logging]

file_logging/enable_file_logging=true
file_logging/log_path="user://logs/lnzlive_debug.log"

[physics]

common/physics_fps=5
3d/physics_engine="Bullet"
3d/active_soft_world=false

[rendering]

quality/driver/driver_name="GLES2"
environment/default_environment="res://default_env.tres"
