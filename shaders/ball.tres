[gd_resource type="ShaderMaterial" load_steps=2 format=2]

[sub_resource type="Shader" id=1]
code = "shader_type spatial;

render_mode unshaded, skip_vertex_transform;

uniform bool debug_mode = true;

uniform bool is_babyz_mode = false;

uniform bool should_quantize = false;
uniform int palette_size = 256;
const vec4 TRANSPARENT_COLOR_MAGENTA = vec4(1.0, 0.0, 1.0, 1.0);
const int TRANSPARENT_COLOR_INDEX = 253;

uniform float eyelid_rotation = 0.0;              // radians: 0 = up, +π/2 = right, –π/2 = left, π = down
uniform int   eyelid_color    = -1;               // palette index

uniform bool  has_eyelashes = false;
uniform int   eyelash_count = 0;
uniform vec4  eyelash_lengths_1; // Lashes 0-3
uniform vec4  eyelash_lengths_2; // Lashes 4-7
uniform float eyelash_angle_rad = 0.0;
uniform float eyelash_spacing_norm = 0.5;
uniform int   eyelash_color_index = 244;

uniform int fuzz_amount = 0;                      // fuzz jitter
uniform int ball_size = 1;                        // diameter in pixels
uniform int outline = -1;                         // outline drawing (-3, draw as nose; -2, shift half R; -1, none; 0, shift half L; 1, shift R + L; 2+, full thickness)
uniform int color_index = 0;                      // fill color from palette index
uniform int outline_color_index = 0;              // outline color from palette index
uniform float z_add = .0;                         // z-offset for z-shading
uniform bool has_texture = false;                 // texture mask flag
uniform sampler2D ball_texture: hint_white;       // texture lookup
uniform bool is_atlas = false;
uniform vec4 atlas_rect;                          // x,y,w,h
uniform vec2 atlas_size;
uniform vec2 texture_size;                        // declared texture mask size from LNZ
uniform vec2 texture_size_raw;                    // actual texture image size from BMP
uniform int transparent_index = 0;                // mask transparency threshold
uniform bool transparency_on = true;              // boolean flag to render palette index 253 alpha = 0
uniform sampler2D palette: hint_white;            // 256-color palette lookup
uniform sampler2D petz_palette: hint_white;       // 256-color palette lookup (base Petz palette)
uniform vec3 z_center_pet_world = vec3(0.0);      // pet origin for depth-based z-shading

uniform vec3 rotation = vec3(0.0);                // rotation in Euler angles
uniform float tiling_unit = 128.0;                // global tiling scale (Reflet: tiles every 128 units in UV space)

uniform bool tile_texture = true;                 // boolean flag for tiling texture vs no rotate texture

uniform int highlight_color_index = -1;           // -1 for none

uniform bool hide_fill = false;
uniform bool hide_outline = false;

varying flat vec2 center_fragcoord;               // coordinate of ball center
varying flat vec4 center_view;                    // view angle for billboarding textures
varying flat float z_center_ball;                 // depth at ball center for z-shading
varying flat float z_center_pet;                  // depth at pet origin for z-shading

varying vec2 mesh_pos;                            // pet‐local XY

// Pseudorandom jitter values for rendering fuzz
float random (float x) {
    return fract(sin(dot(vec2(x),
                         vec2(12.9898,78.233)))*
        43758.5453123);
}

// Apply z-based palette shifts (z-shading)
vec3 get_shifted_color(int palette_index) {
    int new_palette_index;
    if (transparent_index == 1 && palette_index >= 0 && palette_index <= 9) {
        int base_decade = color_index - int(mod(float(color_index), 10.0));
        
        if (palette_index == 0) {
            new_palette_index = ((base_decade - 21) % 120 + 120) % 120;
        } else {
            new_palette_index = (base_decade - 10) + palette_index;
        }
    } else {
        int modded_color = color_index - int(mod(float(color_index), 10.0));
        int amount_to_shift_index = int(mod(float(palette_index), 10.0));
        
        if(z_center_ball < z_center_pet) {
            amount_to_shift_index = int(min(float(amount_to_shift_index + 2), 9.0));
        }
        else if (z_center_ball > z_center_pet) {
            amount_to_shift_index = int(max(float(amount_to_shift_index - 1), 0.0));
        }
        new_palette_index = modded_color + amount_to_shift_index;
    }
    vec3 new_color = texture(palette, vec2(float(new_palette_index)/255.0, 0.0)).rgb;
    return new_color;
}

vec2 calculate_uvs(vec2 offset) {
    vec2 tex_coords;
    if (tile_texture) {
        vec2 uv = offset / float(ball_size) + vec2(0.5);
        uv *= float(ball_size) / texture_size_raw;

        if (is_atlas) {
            vec2 tiled_uv = fract(uv);
            tiled_uv.x = 1.0 - tiled_uv.x;
            tiled_uv.y = 1.0 - tiled_uv.y;
            vec2 atlas_pos = atlas_rect.xy;
            vec2 atlas_dim = atlas_rect.zw;
            tex_coords = (atlas_pos + tiled_uv * atlas_dim) / atlas_size;
        } else {
            tex_coords = fract(uv);
            tex_coords.x = 1.0 - tex_coords.x;
            tex_coords.y = 1.0 - tex_coords.y;
        }
    } else {
        vec2 base_center_offset = (texture_size - texture_size_raw) / 2.0;
        vec2 adj_offset = offset - base_center_offset;
        vec2 snapped_uv = (floor(adj_offset) + 0.5) / texture_size_raw + vec2(0.5);

        if (is_atlas) {
            snapped_uv.x = 1.0 - snapped_uv.x;
            snapped_uv.y = 1.0 - snapped_uv.y;
            vec2 atlas_pos = atlas_rect.xy;
            vec2 atlas_dim = atlas_rect.zw;
            tex_coords = (atlas_pos + snapped_uv * atlas_dim) / atlas_size;
        } else {
            tex_coords = snapped_uv;
            tex_coords.x = 1.0 - tex_coords.x;
            tex_coords.y = 1.0 - tex_coords.y;
        }
    }
    return tex_coords;
}

vec3 get_closest_babyz_color(vec4 original_color, out bool is_transp) {
    if (distance(original_color.rgb, TRANSPARENT_COLOR_MAGENTA.rgb) < 0.01) {
        is_transp = true;
        return TRANSPARENT_COLOR_MAGENTA.rgb;
    }

    vec4 best_color = vec4(0.0);
    float best_distance_sq = 1e20;
    
    for (int i = 0; i < 256; i++) {
        if (i >= palette_size) break;
        if (i == TRANSPARENT_COLOR_INDEX) continue;

        float babyz_normalized_index = (float(i) + 0.5) / float(palette_size);
        vec4 babyz_color = texture(palette, vec2(babyz_normalized_index, 0.5));
        float distance_sq = dot(original_color.rgb - babyz_color.rgb, original_color.rgb - babyz_color.rgb);
        
        if (distance_sq < best_distance_sq) {
            best_distance_sq = distance_sq;
            best_color = babyz_color;
        }
    }
    
    is_transp = false;
    return best_color.rgb;
}

int get_closest_petz_index(vec4 raw_color) {
    if (distance(raw_color.rgb, TRANSPARENT_COLOR_MAGENTA.rgb) < 0.01) {
        return TRANSPARENT_COLOR_INDEX;
    }
    
    int best_index = 0;
    float best_dist = 1e20;
    
    for (int i = 0; i < 256; i++) {
        vec4 p_col = texture(petz_palette, vec2((float(i) + 0.5) / 256.0, 0.5));
        float d = distance(raw_color.rgb, p_col.rgb);
        if (d < best_dist) {
            best_dist = d;
            best_index = i;
        }
    }
    
    return best_index;
}

vec3 apply_palette_shift(int palette_index) {
    if (transparent_index > 0) {
        if (transparent_index == 1 || (palette_index >= transparent_index && palette_index < transparent_index + 10)) {
            return get_shifted_color(palette_index);
        }
    }
    return texture(palette, vec2(float(palette_index) / 255.0, 0.0)).rgb;
}

void fragment() {
    vec2 c = center_fragcoord;
    vec2 st = FRAGCOORD.xy;

    // FUZZING
    // Generates pseudo-random value based on fragment screen coordinates and offsets UV coords for jitter effect
    float r = random(st.y - c.y);
    r = (r * 2.0) - 1.0;
    r *= float(fuzz_amount);
    st.x += floor(r);

    // OUTLINING
    // Assigns inner pixels that will compose outline
    float pct2 = 0.0;
    vec2 st2 = st;
    int modified_outline = outline;
    if(outline == -1) {
        modified_outline = 0;
    }
    else if(outline == 0) {
        st2.x -= 1.0;
        vec2 vec = st2 - c;
        pct2 = step(length(vec), float(ball_size) / 2.0);
        modified_outline = 0;
    } else if (outline == -2) {
        st2.x += 1.0;
        vec2 vec = st2 - c;
        pct2 = step(length(vec), float(ball_size) / 2.0);
        modified_outline = 0;
    } else if (outline == -1) {
        pct2 = 0.0;
        modified_outline = 0;
    } else if (outline > 1) {
        vec2 vec = st2 - c;
        pct2 = step(length(vec), float(ball_size) / 2.0);
        modified_outline -= 1;
    } else if (outline == 1) {
        float side = sign(st2.x - c.x);
        vec2 vec = st2 - c;
        pct2 = step(length(vec), float(ball_size) / 2.0);
        modified_outline = 0;
        st.x += 1.0 * side;
    } else if (outline == -3) {
        vec2 vec = st2 - c;
        pct2 = step(length(vec), float(ball_size) / 2.0);
        modified_outline = 4;
    } else if (outline < -1) {
        float side = sign(st2.x - c.x);
        float side2 = sign(st2.y - c.y);
        st2.x -= 1.0 * side;
        st2.y -= 1.0 * side2;
        vec2 vec = st2 - c;
        pct2 = step(length(vec), float(ball_size) / 2.0);
        modified_outline = 0;
    }

    vec2 vector_from_center = st - c;
    float outdist = length(vector_from_center);
    float ball_radius = float(ball_size) / 2.0;
    float pct = step(outdist, (ball_radius - float(modified_outline)));
    if (outline != -1) {
        pct2 -= pct;
    }

    // HIGHLIGHT
    // Assigns outer pixels that will compose hover highlight
    float highlight_pct = 0.0;

    if (highlight_color_index != -1) {
        float h_inner = ball_radius + 0.5;
        float h_outer = h_inner + 2.0; 
        highlight_pct = step(outdist, h_outer) - step(outdist, h_inner);
    }

    // TEXTURING & QUANTIZING
    // Maps screen or object space to UVs, handling texture atlas rects and texture tiling
    int texture_limit = is_babyz_mode ? 230 : 150;
    vec3 texture_color;
    bool is_transparent = false;

    if (has_texture && color_index >= 10 && color_index < texture_limit) {
        vec2 offset = FRAGCOORD.xy - center_fragcoord;
        vec2 tex_coords = calculate_uvs(offset);

        if (is_atlas) {
            // Samples texture to snap colors to nearest target palette
            vec4 raw_color = texture(ball_texture, tex_coords);
            if (raw_color.a < 0.1) is_transparent = true;

            if (should_quantize) {
                bool transp;
                texture_color = get_closest_babyz_color(raw_color, transp);
                if (transp) is_transparent = true;
            } else {
                int palette_index = get_closest_petz_index(raw_color);
                if (palette_index == TRANSPARENT_COLOR_INDEX || raw_color.a < 0.1) is_transparent = true;
                texture_color = apply_palette_shift(palette_index);
            }
        } else {
            // Get palette index directly from the RED channel for non-atlas textures
            int palette_index = int(texture(ball_texture, tex_coords).r * 255.0);
            
            if (should_quantize) {
                vec4 original_color = texture(petz_palette, vec2(float(palette_index) / 255.0, 0.5));
                bool transp;
                texture_color = get_closest_babyz_color(original_color, transp);
                if (transp) is_transparent = true;
            } else {
                is_transparent = (palette_index == TRANSPARENT_COLOR_INDEX);
                texture_color = apply_palette_shift(palette_index);
            }
        }
    } else {
        // Untextured, if range check failed or has_texture is false
        texture_color = texture(palette, vec2(float(color_index) / 255.0, 0.0)).rgb;
        is_transparent = false;
    }

    // DRAW NOSE
    if (outline == -3) {
        ALBEDO = vec3(pct * vec3(1.0) + pct2 * vec3(0.0));
    } else {
        vec3 outline_color = texture(palette, vec2(float(outline_color_index) / 255.0, 0.0)).rgb;
        ALBEDO = vec3(pct * texture_color.rgb + pct2 * outline_color.rgb);
    }

    // DRAW HIGHLIGHT
    vec3 final_color;
    if (outline == -3) {
        final_color = vec3(pct * vec3(1.0) + pct2 * vec3(0.0));
    } else {
        vec3 outline_color = texture(palette, vec2(float(outline_color_index) / 255.0, 0.0)).rgb;
        final_color = vec3(pct * texture_color.rgb + pct2 * outline_color.rgb);
    }

    // COLOR APPLICATION
    // Applies final albedo, blending base color with outline color
    if (pct + pct2 <= 0.0 && highlight_pct > 0.0) {
        vec3 h_color = texture(palette, vec2(float(highlight_color_index) / 255.0, 0.0)).rgb;
        ALBEDO = h_color;
    } else {
        ALBEDO = final_color;
    }
    
    // DRAW EYELIDS
    // Masks specific sub-regions using rotational matrices for eyelids
    if (eyelid_color != -1) {
        vec2 vc    = mesh_pos * (float(ball_size) * 0.5);
        float half = float(ball_size) * 0.5;
        float dist = length(vc) * 0.5;

        if (dist < half) {
            float rot_c = cos(-eyelid_rotation);
            float rot_s = sin(-eyelid_rotation);
            vec2 vcr = vec2(
                vc.x * rot_c - vc.y * rot_s,
                vc.x * rot_s + vc.y * rot_c
            );
            if (vcr.y > 0.5) {
                vec3 lid_col = texture(
                    palette,
                    vec2(float(eyelid_color)/255.0, 0.0)
                ).rgb;
                ALBEDO = lid_col;
            }
        }
    }

    // DRAW EYELASHES
    // Projects lines outward from the center to render eyelashes
    float lash_mask = 0.0;
    if (has_eyelashes && eyelash_color_index != -1) {
        vec2 vc = mesh_pos * float(ball_size);
        
        float rot_c = cos(-eyelid_rotation);
        float rot_s = sin(-eyelid_rotation);
        vec2 vcr = vec2(vc.x * rot_c - vc.y * rot_s, vc.x * rot_s + vc.y * rot_c);
        
        float total_fan_width = (float(ball_size) * eyelash_spacing_norm) / 2.0;
        float start_x = -total_fan_width * 0.5;
        float denom = max(float(eyelash_count) - 1.0, 1.0);

        for(int i = 0; i < 8; i++) {
            if(i >= eyelash_count) break;
            
            float lash_len = 0.0;
            if (i == 0)      lash_len = eyelash_lengths_1.x;
            else if (i == 1) lash_len = eyelash_lengths_1.y;
            else if (i == 2) lash_len = eyelash_lengths_1.z;
            else if (i == 3) lash_len = eyelash_lengths_1.w;
            else if (i == 4) lash_len = eyelash_lengths_2.x;
            else if (i == 5) lash_len = eyelash_lengths_2.y;
            else if (i == 6) lash_len = eyelash_lengths_2.z;
            else if (i == 7) lash_len = eyelash_lengths_2.w;

            if (lash_len <= 0.0) continue;

            lash_len = lash_len * 0.5;

            float t = float(i) / denom;
            float lash_rot = (t * 2.0 - 1.0) * eyelash_angle_rad;
            
            vec2 dir = vec2(sin(lash_rot), cos(lash_rot));
            vec2 lash_base = vec2(start_x + t * total_fan_width, 0.5) + 0.5;
            vec2 p = vcr - lash_base;

            float proj = dot(p, dir);
            float dist = length(p - dir * proj);
            
            if (proj >= 0.0 && proj <= lash_len && dist <= 0.15) {
                vec4 tex_color = texture(palette, vec2(float(eyelash_color_index)/255.0, 0.0));
                ALBEDO = tex_color.rgb;
                lash_mask = 1.0;
                break; 
            }
        }
    }

    // SET TRANSPARENCY
    // Evaluates distance fields and transparency flags to output final alpha
    float alpha_value = 1.0 - step(pct + pct2 + lash_mask, 0.0);

    if (highlight_pct > 0.0) {
        alpha_value = 1.0;
    }

    if (is_transparent && transparency_on) {
        if (highlight_pct <= 0.0) {
            alpha_value = 0.0;
        }
    }

    if (outline == -4 && highlight_pct <= 0.0) {
        alpha_value = 0.0;
    }

    if (hide_fill && highlight_pct <= 0.0) {
        pct = 0.0;
    }
    
    if (hide_outline && highlight_pct <= 0.0) {
        pct2 = 0.0;
    }

    ALPHA = alpha_value;
    ALPHA_SCISSOR = 1.0;
}

void vertex() {
    
    // Store pet-local XY for eyelids:
    mesh_pos = VERTEX.xy;

    // Billboarding textures aligned to camera view
    MODELVIEW_MATRIX = INV_CAMERA_MATRIX * mat4(CAMERA_MATRIX[0],CAMERA_MATRIX[1],CAMERA_MATRIX[2],WORLD_MATRIX[3]);
    
    // Computes Z-depth of the object center compared to pet root for dynamic palette shifts
    z_center_ball = (MODELVIEW_MATRIX * vec4(0.0, 0.0, 0.0, 1.0)).z;
    z_center_pet = (INV_CAMERA_MATRIX * vec4(z_center_pet_world, 1.0)).z;
    
    // Find the original position of the vertex
    vec3 vert_in_clip_space = (MODELVIEW_MATRIX * vec4(VERTEX, 1.0)).xyz;
    vec4 center_clip_space = MODELVIEW_MATRIX * vec4(vec3(0.0), 1.0);

    // Calculate center fragcoord. Do in vertex shader to avoid calculating per frag.
    center_view = PROJECTION_MATRIX * center_clip_space;
    vec2 center_ndc = (center_view.xy + 1.0) / 2.0;
    center_fragcoord = floor(center_ndc * VIEWPORT_SIZE) + 0.5;
    
    float lash_pad = has_eyelashes ? 10.0 : 0.0; 
    float b = (float(ball_size) / 2.0 + 1.5 + float(fuzz_amount + 3) + lash_pad) / (VIEWPORT_SIZE.x / 2.0);

    // Push vertices outwards by half ball size and fuzz amount
    vert_in_clip_space.z = center_clip_space.z;
    vert_in_clip_space.z += z_add * 0.001;

    vert_in_clip_space.x = center_clip_space.x + b * sign(vert_in_clip_space.x);
    vert_in_clip_space.y = center_clip_space.y + b * sign(vert_in_clip_space.y);
    
    VERTEX = vert_in_clip_space;
}"

[resource]
resource_local_to_scene = true
shader = SubResource( 1 )
shader_param/debug_mode = true
shader_param/is_babyz_mode = false
shader_param/should_quantize = false
shader_param/palette_size = 256
shader_param/eyelid_rotation = 0.0
shader_param/eyelid_color = -1
shader_param/has_eyelashes = false
shader_param/eyelash_count = 0
shader_param/eyelash_lengths_1 = null
shader_param/eyelash_lengths_2 = null
shader_param/eyelash_angle_rad = 0.0
shader_param/eyelash_spacing_norm = 0.25
shader_param/eyelash_color_index = 244
shader_param/fuzz_amount = 0
shader_param/ball_size = 1
shader_param/outline = -1
shader_param/color_index = 0
shader_param/outline_color_index = 0
shader_param/z_add = 0.0
shader_param/has_texture = false
shader_param/is_atlas = false
shader_param/atlas_rect = null
shader_param/atlas_size = null
shader_param/texture_size = null
shader_param/texture_size_raw = null
shader_param/transparent_index = 0
shader_param/transparency_on = true
shader_param/z_center_pet_world = Vector3( 0, 0, 0 )
shader_param/rotation = Vector3( 0, 0, 0 )
shader_param/tiling_unit = 128.0
shader_param/tile_texture = true
shader_param/highlight_color_index = -1
shader_param/hide_fill = false
shader_param/hide_outline = false
