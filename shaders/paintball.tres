[gd_resource type="ShaderMaterial" load_steps=2 format=2]

[sub_resource type="Shader" id=1]
code = "shader_type spatial;

render_mode unshaded, skip_vertex_transform;

uniform bool debug_mode = true;

uniform bool is_babyz_mode = false;

uniform bool should_quantize = false;
uniform int palette_size = 256;
const vec4 TRANSPARENT_COLOR_MAGENTA = vec4(1.0, 0.0, 1.0, 1.0);
const int TRANSPARENT_COLOR_INDEX = 253;

uniform vec3 base_world_position;
uniform int fuzz_amount = 0;
uniform int base_ball_size = 1;
uniform int ball_size = 1;
uniform int outline = -1;
uniform int color_index = 0;
uniform int outline_color_index = 0;
uniform int transparent_index = 0;
uniform bool transparency_on = true;
uniform float z_add = 0.0;
uniform sampler2D palette: hint_white;            // 256-color palette lookup
uniform sampler2D petz_palette: hint_white;       // 256-color palette lookup (base Petz palette)
uniform bool is_atlas = false;
uniform vec4 atlas_rect;
uniform vec2 atlas_size;
uniform vec2 texture_size = vec2(256,256);        // declared texture mask size from LNZ
uniform vec2 texture_size_raw;                    // actual texture image size from BMP
uniform bool has_texture = false;
uniform sampler2D ball_texture: hint_white;
uniform vec3 z_center_pet_world = vec3(0.0);
uniform bool highlight = false;

uniform vec3 rotation = vec3(0.0);                // rotation in Euler angles
uniform float tiling_unit = 128.0;                // global tiling scale (Reflet: tiles every 128 units in UV space)

uniform vec3 pb_normal;                           // direction of paintballz from ballz center

uniform bool tile_texture = true;                 // boolean flag for tiling texture vs no rotate texture

varying flat vec2 center_fragcoord;
varying flat vec2 base_center_fragcoord;
varying flat float z_center_ball;
varying flat float z_center_pet;

float random (float x) {
    return fract(sin(dot(vec2(x),
                         vec2(12.9898,78.233)))*
        43758.5453123);
}

vec3 get_shifted_color(int palette_index) {
    int new_palette_index;

    if (transparent_index == 1 && palette_index >= 0 && palette_index <= 9) {
        int base_decade = color_index - int(mod(float(color_index), 10.0));
        
        if (palette_index == 0) {
            new_palette_index = ((base_decade - 21) % 120 + 120) % 120;
        } else {
            new_palette_index = (base_decade - 10) + palette_index;
        }
    } else {
        int modded_color = color_index - int(mod(float(color_index), 10.0));
        int amount_to_shift_index = int(mod(float(palette_index), 10.0));
        
        if(z_center_ball < z_center_pet) {
            amount_to_shift_index = int(min(float(amount_to_shift_index + 2), 9.0));
        }
        else if (z_center_ball > z_center_pet) {
            amount_to_shift_index = int(max(float(amount_to_shift_index - 1), 0.0));
        }
        new_palette_index = modded_color + amount_to_shift_index;
    }
    vec3 new_color = texture(palette, vec2(float(new_palette_index) / 255.0, 0.0)).rgb;
    return new_color;
}

void fragment() {
    // Discard paintballz going in vectors from ballz centers away from camera 
    vec3 view_normal = (INV_CAMERA_MATRIX * vec4(pb_normal, 0.0)).xyz;

    if (view_normal.z < 0.0) {
        discard;
    }

    vec2 c = center_fragcoord;
    vec2 b = base_center_fragcoord;
    vec2 st = FRAGCOORD.xy;

    // FUZZING
    // Find random number based on y-pixel, offset to center of ball
    float r = random(st.y - c.y);
    // Stretch random number between -1.0 and 1.0
    r = (r * 2.0) - 1.0;
    // Increase distortion by fuzz amount
    r *= float(fuzz_amount);
    // Offset x line by the final random amount
    st.x += floor(r);

    // OUTLINING
    float pct2 = 0.0;
    vec2 st2 = st;
    int modified_outline = outline;

    if(outline == -1) {
        // no outline
        modified_outline = 0;
    }
    else if(outline == 0) {
        // one sided outline
        st2.x -= 1.0;
        vec2 vec = st2 - c;
        pct2 = step(length(vec), float(ball_size) / 2.0);
        modified_outline = 0;
    }
    else if (outline == -2) {
        // one sided outline
        st2.x += 1.0;
        vec2 vec = st2 - c;
        pct2 = step(length(vec), float(ball_size) / 2.0);
        modified_outline = 0;
    }
    else if (outline > 1) {
        vec2 vec = st2 - c;
        pct2 = step(length(vec), float(ball_size) / 2.0);
        modified_outline -= 1;
    }
    else if (outline == 1) {
        // dotted outline
        float side = sign(st2.x - c.x);
        st2.x -= 1.0 * side;
        vec2 vec = st2 - c;
        pct2 = step(length(vec), float(ball_size) / 2.0);
        modified_outline = 0;
    }
    else if (outline < -1) {
        // use as debug for now
        float side = sign(st2.x - c.x);
        float side2 = sign(st2.y - c.y);
        st2.x -= 1.0 * side;
        st2.y -= 1.0 * side2;
        vec2 vec = st2 - c;
        pct2 = step(length(vec), float(ball_size) / 2.0);
        modified_outline = 0;
    }

    // DRAWING
    vec2 vector_from_base_center = st - b;
    vec2 vector_from_center = st - c;
    // Draw a circle.
    // Base ball size gives exact pixel size at camera scale 1.
    float base_pct = step(length(vector_from_base_center), (float(base_ball_size) / 2.0));
    float pct = step(length(vector_from_center), (float(ball_size) / 2.0 - float(modified_outline)));

    pct *= base_pct;

    if(outline != -1)	
        pct2 -= pct;

    pct2 *= base_pct;

    // TEXTURING & QUANTIZING
    vec2 tex_coords;
   int texture_limit = is_babyz_mode ? 230 : 150;

    if (tile_texture) {
        // Global texture tiling (standard behavior)
        vec2 center_uv = (center_fragcoord / VIEWPORT_SIZE) - (1.0);
        vec2 uv = (SCREEN_UV - center_uv) * (1000.0 / texture_size);

        if (is_atlas) {
            vec2 tiled_uv = fract(uv);
            tiled_uv.x = 1.0 - tiled_uv.x;
            tiled_uv.y = 1.0 - tiled_uv.y;
            vec2 atlas_pos = atlas_rect.xy;
            vec2 atlas_dim = atlas_rect.zw;
            tex_coords = (atlas_pos + tiled_uv * atlas_dim) / atlas_size;
        } else {
            tex_coords = uv;
            tex_coords.x = 1.0 - tex_coords.x;
            tex_coords.y = 1.0 - tex_coords.y;
        }
    } else {
        // Get raw pixel offset from ball center
        vec2 offset = FRAGCOORD.xy - center_fragcoord;

        // Adjust for the difference between declared LNZ size and actual BMP size
        vec2 base_center_offset = (texture_size - texture_size_raw) / 2.0;
        offset -= base_center_offset;

        // Targeted center of the texel using floor and adding a half-pixel for pixel-perfect
        vec2 snapped_uv = (floor(offset) + 0.5) / texture_size_raw + vec2(0.5);

        if (is_atlas) {
            // Flip for atlas
            snapped_uv.x = 1.0 - snapped_uv.x;
            snapped_uv.y = 1.0 - snapped_uv.y;
            
            vec2 atlas_pos = atlas_rect.xy;
            vec2 atlas_dim = atlas_rect.zw;
            
            // Map the snapped UV to the atlas coordinates
            tex_coords = (atlas_pos + snapped_uv * atlas_dim) / atlas_size;
        } else {
            tex_coords = snapped_uv;
            // Flip for non-atlas
            tex_coords.x = 1.0 - tex_coords.x;
            tex_coords.y = 1.0 - tex_coords.y;
        }
    }

    vec3 texture_color;
    bool is_transparent = false;

    if (has_texture && color_index >= 10 && color_index < texture_limit) {
        if (is_atlas) {
            vec4 raw_color = texture(ball_texture, tex_coords);
            if (raw_color.a < 0.1) is_transparent = true;
            if (should_quantize) {
                vec4 original_color = raw_color;
                if (distance(original_color.rgb, TRANSPARENT_COLOR_MAGENTA.rgb) < 0.01) {
                    texture_color = TRANSPARENT_COLOR_MAGENTA.rgb;
                    is_transparent = true;
                } else {
                    vec4 best_color = vec4(0.0);
                    float best_distance_sq = 1e20;
                    for (int i = 0; i < 256; i++) {
                        if (i >= palette_size) break;
                        if (i == TRANSPARENT_COLOR_INDEX) continue;
                        float babyz_normalized_index = (float(i) + 0.5) / float(palette_size);
                        vec4 babyz_color = texture(palette, vec2(babyz_normalized_index, 0.5));
                        float d_sq = dot(original_color.rgb - babyz_color.rgb, original_color.rgb - babyz_color.rgb);
                        if (d_sq < best_distance_sq) { best_distance_sq = d_sq; best_color = babyz_color; }
                    }
                    texture_color = best_color.rgb;
                }
            } else {
                vec4 best_color = vec4(0.0);
                float best_dist = 1e20;
                int best_index = 0;
                if (distance(raw_color.rgb, TRANSPARENT_COLOR_MAGENTA.rgb) < 0.01) {
                    best_index = 253;
                } else {
                    for (int i=0; i<256; i++) {
                        vec4 p_col = texture(petz_palette, vec2((float(i) + 0.5)/256.0, 0.5));
                        float d = distance(raw_color.rgb, p_col.rgb);
                        if (d < best_dist) { best_dist = d; best_index = i; }
                    }
                }
                is_transparent = (best_index == 253);
                if (raw_color.a < 0.1) is_transparent = true;
                if (transparent_index > 0) {
                    if(transparent_index == 1 || (best_index >= transparent_index && best_index < transparent_index + 10)) {
                        texture_color = get_shifted_color(best_index);
                    } else {
                        texture_color = texture(palette, vec2(float(best_index) / 255.0, 0.0)).rgb;
                    }
                } else {
                    texture_color = texture(palette, vec2(float(best_index) / 255.0, 0.0)).rgb;
                }
            }
        } else if (should_quantize) {
            int p_idx = int(texture(ball_texture, tex_coords).r * 255.0);
            vec4 orig_col = texture(petz_palette, vec2(float(p_idx)/255.0, 0.5));
            if (distance(orig_col.rgb, TRANSPARENT_COLOR_MAGENTA.rgb) < 0.01) {
                texture_color = TRANSPARENT_COLOR_MAGENTA.rgb;
                is_transparent = true;
            } else {
                vec4 best_color = vec4(0.0);
                float best_d_sq = 1e20;
                for (int i = 0; i < 256; i++) {
                    if (i >= palette_size) break;
                    if (i == TRANSPARENT_COLOR_INDEX) continue;
                    float babyz_normalized_index = (float(i) + 0.5) / float(palette_size);
                    vec4 babyz_color = texture(palette, vec2(babyz_normalized_index, 0.5));
                    float d_sq = dot(orig_col.rgb - babyz_color.rgb, orig_col.rgb - babyz_color.rgb);
                    if (d_sq < best_d_sq) { best_d_sq = d_sq; best_color = babyz_color; }
                }
                texture_color = best_color.rgb;
            }
        } else {
            int p_idx = int(texture(ball_texture, tex_coords).r * 255.0);
            is_transparent = (p_idx == 253);
            if (transparent_index > 0) {
                if(transparent_index == 1 || (p_idx >= transparent_index && p_idx < transparent_index + 10)) {
                    texture_color = get_shifted_color(p_idx);
                } else {
                    texture_color = texture(palette, vec2(float(p_idx) / 255.0, 0.0)).rgb;
                }
            } else {
                texture_color = texture(palette, vec2(float(p_idx) / 255.0, 0.0)).rgb;
            }
        }
    } else {
        // untextured, if range check failed or has_texture is false
        texture_color = texture(palette, vec2(float(color_index) / 255.0, 0.0)).rgb;
        is_transparent = false;
    }
    
    vec3 outline_color = texture(palette, vec2(float(outline_color_index) / 255.0, 0.0)).rgb;
    ALBEDO = vec3(pct * texture_color.rgb + pct2 * outline_color.rgb);

    // Adjust ALPHA based on conditions
    float alpha_value = 1.0;
    if (pct + pct2 == 0.0 || is_transparent) {
        alpha_value = 0.0;
    }

    ALPHA = alpha_value;
    ALPHA_SCISSOR = 1.0;

    if (highlight) {
        ALBEDO = vec3(1.0, 1.0, 0.0);
    }
}

void vertex() {
	// Billboard and retain scaling
	MODELVIEW_MATRIX = INV_CAMERA_MATRIX * mat4(CAMERA_MATRIX[0],CAMERA_MATRIX[1],CAMERA_MATRIX[2],WORLD_MATRIX[3]);
	
	z_center_ball = (MODELVIEW_MATRIX * vec4(0.0, 0.0, 0.0, 1.0)).z;
	z_center_pet = (INV_CAMERA_MATRIX * vec4(z_center_pet_world, 1.0)).z;
	
	// Find the original position of the vertex
	vec3 vert_in_clip_space = (MODELVIEW_MATRIX * vec4(VERTEX, 1.0)).xyz;
	
	vec4 center_clip_space = MODELVIEW_MATRIX * vec4(vec3(0.0), 1.0);
	// Calculate center fragcoord. Do in vertex shader to avoid calculating per frag.
	vec4 center_view = PROJECTION_MATRIX * center_clip_space;
	vec2 center_ndc = (center_view.xy + 1.0) / 2.0;
	// Must be an exact pixel coordinate or you get strange pixel effects
	center_fragcoord = floor(center_ndc * VIEWPORT_SIZE) + 0.5;
	
	vec4 base_center_clip_space = INV_CAMERA_MATRIX * vec4(base_world_position, 1.0);
	// Calculate center fragcoord. Do in vertex shader to avoid calculating per frag.
	vec4 base_center_view = PROJECTION_MATRIX * base_center_clip_space;
	vec2 base_center_ndc = (base_center_view.xy + 1.0) / 2.0;
	
	base_center_fragcoord = floor(base_center_ndc * VIEWPORT_SIZE) + 0.5;
	
	if (vert_in_clip_space.z - base_center_clip_space.z > 0.0) {
		vert_in_clip_space.z = base_center_clip_space.z + 0.001;
	}
//	vert_in_clip_space.z = center_clip_space.z;
	vert_in_clip_space.z += z_add * 0.001;
	float b = (float(ball_size) / 2.0 + float(fuzz_amount + 3)) / (VIEWPORT_SIZE.x / 2.0);
	vert_in_clip_space.x = center_clip_space.x + b * sign(vert_in_clip_space.x);
	vert_in_clip_space.y = center_clip_space.y + b * sign(vert_in_clip_space.y);
	
	VERTEX = vert_in_clip_space;
}"

[resource]
resource_local_to_scene = true
shader = SubResource( 1 )
shader_param/debug_mode = true
shader_param/should_quantize = false
shader_param/palette_size = 256
shader_param/base_world_position = Vector3( 0, 0, 0 )
shader_param/fuzz_amount = 0
shader_param/base_ball_size = 10
shader_param/ball_size = 10
shader_param/outline = -1
shader_param/color_index = -1
shader_param/outline_color_index = 0
shader_param/transparent_index = 0
shader_param/transparency_on = true
shader_param/z_add = 0.0
shader_param/is_atlas = false
shader_param/atlas_rect = null
shader_param/atlas_size = null
shader_param/texture_size = Vector2( 256, 256 )
shader_param/texture_size_raw = null
shader_param/has_texture = false
shader_param/z_center_pet_world = Vector3( 0, 0, 0 )
shader_param/highlight = false
shader_param/rotation = Vector3( 0, 0, 0 )
shader_param/tiling_unit = 128.0
shader_param/pb_normal = null
shader_param/tile_texture = true
