[gd_resource type="ShaderMaterial" load_steps=2 format=2]

[sub_resource type="Shader" id=1]
code = "shader_type spatial;

render_mode unshaded, skip_vertex_transform, cull_disabled;

uniform bool debug_mode = true;

uniform bool should_quantize = false;
uniform int palette_size = 256;
const vec4 TRANSPARENT_COLOR_MAGENTA = vec4(1.0, 0.0, 1.0, 1.0);
const int TRANSPARENT_COLOR_INDEX = 253;

uniform int color_index = 0;
uniform int l_edge_color = 0;
uniform int r_edge_color = 0;
uniform int fuzz_amount = 0;
uniform int transparent_index = 0;
uniform sampler2D palette: hint_white;            // 256-color palette lookup
uniform sampler2D petz_palette: hint_white;       // 256-color palette lookup (base Petz palette)
uniform vec2 texture_size = vec2(256,256);        // declared texture mask size from LNZ
uniform vec2 texture_size_raw;                    // actual texture image size from BMP
uniform bool is_atlas = false;
uniform vec4 atlas_rect;
uniform vec2 atlas_size;
uniform sampler2D polygon_texture: hint_white;
uniform bool has_texture = false;
varying flat float z_center_line;
varying flat float z_center_pet;
uniform vec3 z_center = vec3(0.0);

uniform vec3 ball_world_pos1 = vec3(0.0);
uniform vec3 ball_world_pos2 = vec3(0.0);
uniform vec3 ball_world_pos3 = vec3(0.0);
uniform vec3 ball_world_pos4 = vec3(0.0);
uniform bool highlight = false;

float random(float x) {
    return fract(sin(dot(vec2(x), vec2(12.9898, 78.233))) * 43758.5453123);
}

vec3 get_shifted_color(int palette_index) {
	int modded_color = color_index - int(mod(float(color_index), 10.0));
	int amount_to_shift_index = int(mod(float(palette_index), 10.0));
	if(z_center_line < z_center_pet) {
		amount_to_shift_index = int(min(float(amount_to_shift_index + 2), 9.0));
	}
	else if (z_center_line > z_center_pet) {
		amount_to_shift_index = int(max(float(amount_to_shift_index - 1), 0.0));
	}
	int new_palette_index = modded_color + amount_to_shift_index;
	vec3 new_color = texture(palette, vec2(float(new_palette_index)/255.0, 0.0)).rgb;
	return new_color;
}

void fragment() {
    vec2 uv = UV;

    // Handle edge fuzziness
    float fuzz_factor = random(uv.x + uv.y) * float(fuzz_amount) / 100.0;

    // TEXTURING & QUANTIZING
    //vec2 tex_coords = uv * texture_size_raw;

    vec2 uv_scaled = uv * (1000.0 / texture_size_raw);
    vec2 tex_coords;

    if (is_atlas) {
        vec2 tiled_uv = fract(uv_scaled);
        // tiled_uv.x = 1.0 - tiled_uv.x;
        // tiled_uv.y = 1.0 - tiled_uv.y;
        vec2 atlas_pos = atlas_rect.xy;
        vec2 atlas_dim = atlas_rect.zw;
        tex_coords = (atlas_pos + tiled_uv * atlas_dim) / atlas_size;
    } else {
        tex_coords = uv_scaled;
    }

    vec3 texture_color;
    bool is_transparent = false;
    int palette_index;

    if (is_atlas && has_texture) {
         vec4 raw_color = texture(polygon_texture, tex_coords);
         // Handle transparency from PNG alpha
         if (raw_color.a < 0.1) is_transparent = true;

         if (should_quantize) {
             // Babyz mode: raw_color is (presumably) Petz RGB. Quantize to Babyz Palette.
             vec4 original_color = raw_color;

             if (distance(original_color.rgb, TRANSPARENT_COLOR_MAGENTA.rgb) < 0.01) {
                texture_color = TRANSPARENT_COLOR_MAGENTA.rgb;
                is_transparent = true;
             } else {
                 vec4 best_color = vec4(0.0);
                 float best_distance_sq = 1e20;

                 const int MAX_PALETTE_SIZE = 256;
                 for (int i = 0; i < MAX_PALETTE_SIZE; i++) {
                     if (i >= palette_size) {
                         break;
                     }

                     if (i == TRANSPARENT_COLOR_INDEX) {
                         continue;
                     }
                     // Normalized palette index for Babyz palette sampling
                     float babyz_normalized_index = (float(i) + 0.5) / float(palette_size);
                     vec4 babyz_color = texture(palette, vec2(babyz_normalized_index, 0.5));
                     float distance_sq = dot(original_color.rgb - babyz_color.rgb, original_color.rgb - babyz_color.rgb);

                     if (distance_sq < best_distance_sq) {
                         best_distance_sq = distance_sq;
                         best_color = babyz_color;
                     }
                 }
                 texture_color = best_color.rgb;
             }
         } else {
             // Petz mode: raw_color is RGB.
             vec4 best_color = vec4(0.0);
             float best_dist = 1e20;
             int best_index = 0;

             // Check for magenta transparency first
             if (distance(raw_color.rgb, TRANSPARENT_COLOR_MAGENTA.rgb) < 0.01) {
                 best_index = 253;
             } else {
                 // Loop over petz_palette to find index
                 for (int i=0; i<256; i++) {
                     vec4 p_col = texture(petz_palette, vec2((float(i) + 0.5)/256.0, 0.5));
                     float d = distance(raw_color.rgb, p_col.rgb);
                     if (d < best_dist) { best_dist = d; best_index = i; }
                 }
             }

             is_transparent = (palette_index == 253);
             if (raw_color.a < 0.1) is_transparent = true;

             if (transparent_index > 0 && color_index >= 10 && color_index < 150) {
                if(transparent_index == 1 || (best_index >= transparent_index && best_index < transparent_index + 10)) {
                    texture_color = get_shifted_color(best_index);
                } else {
                    texture_color = texture(palette, vec2(float(best_index) / float(palette_size), 0.5)).rgb;
                }
            } else if (transparent_index == 0 && color_index >= 10 && color_index < 150) {
                texture_color = texture(palette, vec2(float(best_index) / float(palette_size), 0.5)).rgb;
            } else {
                texture_color = texture(palette, vec2(float(color_index) / float(palette_size), 0.5)).rgb;
            }
         }
    } else if (should_quantize && has_texture) {
        // Get palette index from texture
        palette_index = int(texture( polygon_texture, tex_coords).r * 255.0);

        // Normalized palette index for texture sampling
        float petz_normalized_index = float(palette_index) / float(palette_size);

        // Look up RGB color using the Petz palette
        vec4 original_color = texture(petz_palette, vec2(petz_normalized_index, 0.5));
        
        // Quantize color to the Babyz palette
        if (distance(original_color.rgb, TRANSPARENT_COLOR_MAGENTA.rgb) < 0.01) {
            texture_color = TRANSPARENT_COLOR_MAGENTA.rgb;
            is_transparent = true;
        } else {
            vec4 best_color = vec4(0.0);
            float best_distance_sq = 1e20;
            
            const int MAX_PALETTE_SIZE = 256;
            for (int i = 0; i < MAX_PALETTE_SIZE; i++) {
                if (i >= palette_size) {
                    break;
                }
            
                if (i == TRANSPARENT_COLOR_INDEX) {
                    continue;
                }
                // Normalized palette index for Babyz palette sampling
                float babyz_normalized_index = (float(i) + 0.5) / float(palette_size);
                vec4 babyz_color = texture(palette, vec2(babyz_normalized_index, 0.5));
                float distance_sq = dot(original_color.rgb - babyz_color.rgb, original_color.rgb - babyz_color.rgb);
                
                if (distance_sq < best_distance_sq) {
                    best_distance_sq = distance_sq;
                    best_color = babyz_color;
                }
            }
            texture_color = best_color.rgb;
        }
    } else {
        palette_index = int(texture( polygon_texture, tex_coords).r * 255.0);
        is_transparent = (palette_index == 253);

        if (transparent_index > 0 && color_index >= 10 && color_index < 150 && has_texture) {
            if(transparent_index == 1 || (palette_index >= transparent_index && palette_index < transparent_index + 10)) {
                texture_color = get_shifted_color(palette_index);
            } else {
                texture_color = texture(palette, vec2(float(palette_index) / float(palette_size), 0.5)).rgb;
            }
        } else if (transparent_index == 0 && color_index >= 10 && color_index < 150 && has_texture) {
            texture_color = texture(palette, vec2(float(palette_index) / float(palette_size), 0.5)).rgb;
        } else {
            texture_color = texture(palette, vec2(float(color_index) / float(palette_size), 0.5)).rgb;
        }
    }

    // Add left and right edge coloring
    if (uv.x < 0.05 && l_edge_color != -1) {
        texture_color = get_shifted_color(l_edge_color);
    } else if (uv.x > 0.95 && r_edge_color != -1) {
        texture_color = get_shifted_color(r_edge_color);
    }

    ALBEDO = texture_color * (1.0 - fuzz_factor);
    ALPHA = 1.0;

    if (highlight) {
        ALBEDO = vec3(1.0, 1.0, 0.0);
    }
}

void vertex() {
    // Interpolate the positions based on UV coordinates
    vec3 interp_pos1 = mix(ball_world_pos1, ball_world_pos2, UV.x);
    vec3 interp_pos2 = mix(ball_world_pos4, ball_world_pos3, UV.x);
    vec3 final_position = mix(interp_pos1, interp_pos2, UV.y);

    // Set the final vertex position using the calculated 3D position
    VERTEX = (MODELVIEW_MATRIX * vec4(final_position, 1.0)).xyz;
}"

[resource]
resource_local_to_scene = true
shader = SubResource( 1 )
shader_param/debug_mode = true
shader_param/should_quantize = false
shader_param/palette_size = 256
shader_param/color_index = 0
shader_param/l_edge_color = 0
shader_param/r_edge_color = 0
shader_param/fuzz_amount = 0
shader_param/transparent_index = 0
shader_param/texture_size = Vector2( 256, 256 )
shader_param/texture_size_raw = null
shader_param/is_atlas = false
shader_param/atlas_rect = null
shader_param/atlas_size = null
shader_param/has_texture = false
shader_param/z_center = Vector3( 0, 0, 0 )
shader_param/ball_world_pos1 = Vector3( 0, 0, 0 )
shader_param/ball_world_pos2 = Vector3( 0, 0, 0 )
shader_param/ball_world_pos3 = Vector3( 0, 0, 0 )
shader_param/ball_world_pos4 = Vector3( 0, 0, 0 )
shader_param/highlight = false
