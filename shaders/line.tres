[gd_resource type="ShaderMaterial" load_steps=2 format=2]

[sub_resource type="Shader" id=1]
code = "shader_type spatial;

render_mode unshaded, skip_vertex_transform;

uniform bool debug_mode = true;

uniform bool is_babyz_mode = false;

uniform bool should_quantize = false;
uniform int palette_size = 256;
const vec4 TRANSPARENT_COLOR_MAGENTA = vec4(1.0, 0.0, 1.0, 1.0);
const int TRANSPARENT_COLOR_INDEX = 253;

uniform int line_width_in_pixels_start = 20;
uniform int fuzz_amount = 0;
uniform int line_width_in_pixels_end = 20;
uniform int color_index = 0;
uniform int l_color_index = 0;
uniform int r_color_index = 0;
uniform int full_outline = 0;
uniform int draw_order = 0;
varying flat vec2 center_of_line;
varying flat vec2 center_of_line_screen_uv;
varying float line_width_in_pixels;
varying flat vec2 uv_to_flat;
varying flat vec2 normal_v;
uniform vec3 ball_world_pos1 = vec3(0.0);
uniform vec3 ball_world_pos2 = vec3(0.0);
uniform sampler2D line_texture: hint_white;
uniform int transparent_index = 0;
uniform bool transparency_on = true;
uniform sampler2D palette: hint_white;            // 256-color palette lookup
uniform sampler2D petz_palette: hint_white;       // 256-color palette lookup (base Petz palette)
uniform bool is_atlas = false;
uniform vec4 atlas_rect;
uniform vec2 atlas_size;
uniform vec2 texture_size = vec2(256,256);        // declared texture mask size from LNZ
uniform vec2 texture_size_raw;                    // actual texture image size from BMP
varying vec2 uv_mod;
varying vec2 max_x;
uniform bool has_texture = false;
varying flat float z_center_line;
varying flat float z_center_pet;
uniform vec3 z_center = vec3(0.0);
uniform bool highlight = false;

float random (float x) {
    return fract(sin(dot(vec2(x),
                         vec2(12.9898,78.233)))*
        43758.5453123);
}

vec3 get_shifted_color(int palette_index) {
	int new_palette_index;
	if (transparent_index == 1 && palette_index >= 0 && palette_index <= 9) {
		int base_decade = color_index - int(mod(float(color_index), 10.0));
		if (palette_index == 0) {
			new_palette_index = ((base_decade - 21) % 120 + 120) % 120;
		} else {
			new_palette_index = (base_decade - 10) + palette_index;
		}
	} else {
		int modded_color = color_index - int(mod(float(color_index), 10.0));
		int amount_to_shift_index = int(mod(float(palette_index), 10.0));
		
		if(z_center_line < z_center_pet) {
			amount_to_shift_index = int(min(float(amount_to_shift_index + 2), 9.0));
		}
		else if (z_center_line > z_center_pet) {
			amount_to_shift_index = int(max(float(amount_to_shift_index - 1), 0.0));
		}
		new_palette_index = modded_color + amount_to_shift_index;
	}
	vec3 new_color = texture(palette, vec2(float(new_palette_index) / float(palette_size), 0.5)).rgb;
	return new_color;
}

void fragment() {
    vec2 st = FRAGCOORD.xy;

    vec2 absolute_center = center_of_line;

    // FUZZING
    float r = random(st.y - absolute_center.y);
    r = (r * 2.0) - 1.0;
    r *= float(fuzz_amount) / 20.0;

    // Rescale the UV between 0 and 1
    float scaled_uv_x = uv_mod.x / max_x.x;
    vec2 move_vec = normal_v * r;
    vec2 modified_uv = vec2(scaled_uv_x, UV.y) - move_vec;
    float one_pixel = 0.5 / (floor(line_width_in_pixels) + 0.5);

    // TEXTURING & QUANTIZING
    vec2 uv = (SCREEN_UV - center_of_line_screen_uv) * (1000.0 / texture_size_raw);
    vec2 tex_coords;
   int texture_limit = is_babyz_mode ? 230 : 150;

    if (is_atlas) {
        vec2 tiled_uv = fract(uv);
        // tiled_uv.x = 1.0 - tiled_uv.x;
        // tiled_uv.y = 1.0 - tiled_uv.y;
        vec2 atlas_pos = atlas_rect.xy;
        vec2 atlas_dim = atlas_rect.zw;
        tex_coords = (atlas_pos + tiled_uv * atlas_dim) / atlas_size;
    } else {
        tex_coords = uv;
    }

    vec3 texture_color;
    bool is_transparent = false;

    bool is_right_edge = modified_uv.x < 0.25 + one_pixel;
    bool is_left_edge  = modified_uv.x > 0.75 - one_pixel;
    bool is_any_edge = is_right_edge || is_left_edge;

    if (is_right_edge && r_color_index != -1) {
        texture_color = texture(palette, vec2(float(r_color_index) / float(palette_size), 0.5)).rgb;
    } else if (is_left_edge && l_color_index != -1) {
        texture_color = texture(palette, vec2(float(l_color_index) / float(palette_size), 0.5)).rgb;
    } else {
        if (has_texture && color_index >= 10 && color_index < texture_limit) {
            if (is_atlas) {
                 vec4 raw_color = texture(line_texture, tex_coords);
                 if (raw_color.a < 0.1) is_transparent = true;
                 if (should_quantize) {
                    // textured, atlas, quantized
                     vec4 original_color = raw_color;
                     if (distance(original_color.rgb, TRANSPARENT_COLOR_MAGENTA.rgb) < 0.01) {
                        texture_color = TRANSPARENT_COLOR_MAGENTA.rgb;
                        is_transparent = true;
                     } else {
                         vec4 best_color = vec4(0.0);
                         float best_distance_sq = 1e20;
                         for (int i = 0; i < 256; i++) {
                             if (i >= palette_size) break;
                             if (i == TRANSPARENT_COLOR_INDEX) continue;
                             float babyz_normalized_index = (float(i) + 0.5) / float(palette_size);
                             vec4 babyz_color = texture(palette, vec2(babyz_normalized_index, 0.5));
                             float d_sq = dot(original_color.rgb - babyz_color.rgb, original_color.rgb - babyz_color.rgb);
                             if (d_sq < best_distance_sq) { best_distance_sq = d_sq; best_color = babyz_color; }
                         }
                         texture_color = best_color.rgb;
                     }
                 } else {
                     vec4 best_color = vec4(0.0);
                     float best_dist = 1e20;
                     int best_index = 0;
                     if (distance(raw_color.rgb, TRANSPARENT_COLOR_MAGENTA.rgb) < 0.01) {
                         best_index = 253;
                     } else {
                         for (int i=0; i<256; i++) {
                             vec4 p_col = texture(petz_palette, vec2((float(i) + 0.5)/256.0, 0.5));
                             float d = distance(raw_color.rgb, p_col.rgb);
                             if (d < best_dist) { best_dist = d; best_index = i; }
                         }
                     }
                     is_transparent = (best_index == 253);
                     if (raw_color.a < 0.1) is_transparent = true;
                     if (transparent_index > 0) {
                        if(transparent_index == 1 || (best_index >= transparent_index && best_index < transparent_index + 10)) {
                            texture_color = get_shifted_color(best_index);
                        } else {
                            texture_color = texture(palette, vec2(float(best_index) / float(palette_size), 0.5)).rgb;
                        }
                    } else {
                        texture_color = texture(palette, vec2(float(best_index) / float(palette_size), 0.5)).rgb;
                    }
                 }
            } else if (should_quantize) {
                int p_idx = int(texture(line_texture, tex_coords).r * 255.0);
                vec4 orig_col = texture(petz_palette, vec2(float(p_idx)/255.0, 0.5));
                if (distance(orig_col.rgb, TRANSPARENT_COLOR_MAGENTA.rgb) < 0.01) {
                    texture_color = TRANSPARENT_COLOR_MAGENTA.rgb;
                    is_transparent = true;
                } else {
                    vec4 best_color = vec4(0.0);
                    float best_d_sq = 1e20;
                    for (int i = 0; i < 256; i++) {
                        if (i >= palette_size) break;
                        if (i == TRANSPARENT_COLOR_INDEX) continue;
                        float babyz_normalized_index = (float(i) + 0.5) / float(palette_size);
                        vec4 babyz_color = texture(palette, vec2(babyz_normalized_index, 0.5));
                        float d_sq = dot(orig_col.rgb - babyz_color.rgb, orig_col.rgb - babyz_color.rgb);
                        if (d_sq < best_d_sq) { best_d_sq = d_sq; best_color = babyz_color; }
                    }
                    texture_color = best_color.rgb;
                }
            } else {
                int p_idx = int(texture(line_texture, tex_coords).r * 255.0);
                is_transparent = (p_idx == 253);
                if (transparent_index > 0) {
                    if(transparent_index == 1 || (p_idx >= transparent_index && p_idx < transparent_index + 10)) {
                        texture_color = get_shifted_color(p_idx);
                    } else {
                        texture_color = texture(palette, vec2(float(p_idx) / float(palette_size), 0.5)).rgb;
                    }
                } else {
                    texture_color = texture(palette, vec2(float(p_idx) / float(palette_size), 0.5)).rgb;
                }
            }
        } else {
            // untextured, if range check failed or has_texture is false
            texture_color = texture(palette, vec2(float(color_index) / float(palette_size), 0.5)).rgb;
            is_transparent = false;
        }
    }

    ALBEDO = texture_color.rgb;

    // DEBUG: magenta color
    // ALBEDO = vec3(1.0, 0.0, 1.0); 
    
    if (full_outline == 1 && is_any_edge) {
        DEPTH = 0.0; 
    } 
    else if (draw_order == 1) {
        DEPTH = 0.00001;
    }
    else {
        DEPTH = FRAGCOORD.z;
    }

    float alpha_value = 1.0;

    if (modified_uv.x < 0.25 || modified_uv.x > 0.75) {
        alpha_value = 0.0;
    } 
    else {
        if (full_outline == 1 && is_any_edge) {
            alpha_value = 1.0;
        } 
        else if (is_transparent && transparency_on) {
            alpha_value = 0.0;
        }
    }

    ALPHA = alpha_value;
    ALPHA_SCISSOR = 1.0;

    if (highlight) {
        ALBEDO = vec3(1.0, 1.0, 0.0);
    }
}

void vertex() {
	mat4 projection = PROJECTION_MATRIX * MODELVIEW_MATRIX;
	
	// Find the original position of the vertex
	vec4 vert_in_clip_space = projection * vec4(VERTEX, 1.0);
	vec2 vert_in_ndc_space = vert_in_clip_space.xy / vert_in_clip_space.w;
	
	// Find the opposite pair of the vertex.
	// The mesh has a slight x-width to allow us to find the orientation later
	// So when we come to give the line a fixed pixel width,
	// We need to remove that x-width from the total later.
	vec4 paired_point = vec4(VERTEX + vec3(-VERTEX.x, 0, 0), 1.0);
	vec4 paired_point_clip_space = projection * paired_point;
	vec2 paired_point_ndc_space = paired_point_clip_space.xy / paired_point_clip_space.w;
	
	// Find the opposite end of the line
	vec4 next_point = vec4(VERTEX + vec3(0, -1.0, 0), 1.0);
	vec4 next_point_clip_space = projection * next_point;
	vec2 next_point_ndc_space = next_point_clip_space.xy / next_point_clip_space.w;
	
	// Find the normal, i.e. direction we want to shove the vertices
	vec2 line_direction_onscreen = normalize(next_point_ndc_space - vert_in_ndc_space);
	vec2 normal = vec2(-line_direction_onscreen.y, line_direction_onscreen.x);
	uv_to_flat = normalize(normal - vec2(1.0, 0.0));
	normal_v = normal;
	
	// Depending on which side of the mesh this vertex is on,
	// We want to shove the vertex either left or right
	float orientation = 1.0;
	if (VERTEX.x < 0.0 ) {
		orientation = -1.0;
	}
	
	// Depending on line end, set line width
	line_width_in_pixels = float(line_width_in_pixels_start);
	if(VERTEX.y < 0.0) {
		line_width_in_pixels = float(line_width_in_pixels_end);
	}
	
	// Note - this requires that camera is set to 'keep width'
	vec2 n = floor(normal * line_width_in_pixels * 2.0) * orientation;
	vec3 offset = vec3(n / VIEWPORT_SIZE, 0.0);
	
	// Remove the mesh's default x-width from the final output
	vec2 existing_width = vert_in_ndc_space - paired_point_ndc_space;
	offset.xy -= existing_width;
	
	float z_pos = vert_in_clip_space.z;
	// Find the minimum z for this line
	if (!(ball_world_pos1 == vec3(0.0) && ball_world_pos2 == vec3(0.0))) {
        vec4 ball_screen_pos1 = PROJECTION_MATRIX * INV_CAMERA_MATRIX * vec4(ball_world_pos1, 1.0);
        vec4 ball_screen_pos2 = PROJECTION_MATRIX * INV_CAMERA_MATRIX * vec4(ball_world_pos2, 1.0);
        
        if (draw_order == 1) {
            // Draw linez over ballz
            z_pos = min(ball_screen_pos1.z, ball_screen_pos2.z);
        } else {
            // Draw linez under ballz
            z_pos = max(ball_screen_pos1.z, ball_screen_pos2.z);
        }
    }

    if (full_outline == 1) {
        VERTEX = vec3(vert_in_ndc_space, z_pos) + offset;
    } else {
        VERTEX = vec3(vert_in_ndc_space, z_pos + 0.001 / 1000.0) + offset;
    }
	
	// Calculate center fragcoord. Do in vertex shader to avoid calculating per frag.
	vec4 center_view = projection * vec4(vec3(0.0), 1.0);
	vec2 center_ndc = (center_view.xy + 1.0) / 2.0;
	// Must be an exact pixel coordinate or you get strange pixel effects
	center_of_line = floor(center_ndc * VIEWPORT_SIZE) + 0.5;
	center_of_line_screen_uv = center_ndc;
	
	float max_x_f = line_width_in_pixels / max(float(line_width_in_pixels_end), float(line_width_in_pixels_start));
	uv_mod = UV;
	if(UV.x > 0.0)
		uv_mod.x = max_x_f;
	max_x = vec2(max_x_f, 0.0);
	
	z_center_line = (MODELVIEW_MATRIX * vec4(0.0, 0.0, 0.0, 1.0)).z;
	z_center_pet = (INV_CAMERA_MATRIX * vec4(z_center, 1.0)).z;
	
	PROJECTION_MATRIX = mat4(1.0);
}"

[resource]
resource_local_to_scene = true
shader = SubResource( 1 )
shader_param/debug_mode = true
shader_param/is_babyz_mode = false
shader_param/should_quantize = false
shader_param/palette_size = 256
shader_param/line_width_in_pixels_start = 20
shader_param/fuzz_amount = 0
shader_param/line_width_in_pixels_end = 20
shader_param/color_index = 0
shader_param/l_color_index = 0
shader_param/r_color_index = 0
shader_param/full_outline = 0
shader_param/draw_order = 0
shader_param/ball_world_pos1 = Vector3( 0, 0, 0 )
shader_param/ball_world_pos2 = Vector3( 0, 0, 0 )
shader_param/transparent_index = 0
shader_param/transparency_on = true
shader_param/is_atlas = false
shader_param/atlas_rect = null
shader_param/atlas_size = null
shader_param/texture_size = Vector2( 256, 256 )
shader_param/texture_size_raw = null
shader_param/has_texture = false
shader_param/z_center = Vector3( 0, 0, 0 )
shader_param/highlight = false
